<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="app"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(${appName})] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="!local">
        <!-- Non-local: structured single-line output (easier to grep in prod/docker) -->
        <appender name="STRUCTURED" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [${appName}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="STRUCTURED"/>
        </root>
    </springProfile>

    <springProfile name="local">
        <!-- Local dev: coloured output -->
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
